rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isVerifiedUser() {
      return signedIn() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.verification_status == 'verified';
    }

    function isImage() {
      return request.resource != null &&
        request.resource.contentType.matches('image/.*') &&
        request.resource.size < 10 * 1024 * 1024;
    }

    match /reports/{fileName} {
      allow read: if true;
      allow write: if isVerifiedUser() && isImage();
      allow delete: if isAdmin();
    }

    match /users/{userId}/verification/{type}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isImage();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
